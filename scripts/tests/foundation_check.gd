	var initial_road: Dictionary = surface.get("baccarat_road", {}) if typeof(surface.get("baccarat_road", {})) == TYPE_DICTIONARY else {}
	if str(initial_road.get("type", "")) != "bead_plate" or int(initial_road.get("rows", 0)) <= 0:
