  "canvas_contracts": {
    "environment_backgrounds": {
      "size": [900, 430],
      "camera": "first-person venue view, player body unseen",
      "safe_zones": {
        "hud": "top 48px at 1280x720 design space",
        "inspector": "bottom 136px at 1280x720 design space",
        "scene_hotspots": "interactive objects should remain visually readable under translucent hit regions"
      }
    },
    "game_surfaces": {
      "size": [900, 430],
      "camera": "first-person game/table/machine surface",
      "safe_zones": {
        "dynamic_cards_dice_reels": "leave center space open for procedural game pieces",
        "cast": "right side can show dealer, bartender, camera, or watcher"
      }
    },
    "icons": {
      "size": [32, 32],
      "style": "hard-edge pixel art, transparent background preferred"
    }
  },
